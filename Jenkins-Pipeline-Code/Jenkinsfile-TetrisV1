pipeline {
    agent any
    tools {
        nodejs 'nodejs'
    }
    environment {
        SCANNER_HOME=tool 'sonar-scanner'
    }
    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Checkout from Git') {
            steps {
                git branch: 'main', url: 'https://github.com/kamonphankanthayod/devsecops-game-pipeline.git'
            }
        }
        stage('Sonarqube Analysis') {
            steps {
                dir('Tetris-V1') {
                    withSonarQubeEnv('sonar-scanner') {
                        sh ''' $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=Tetris \
                        -Dsonar.projectKey=Tetris '''
                    }
                }
            }
        }
        stage('Quality Check') {
            steps {
                script {
                    waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token'
                }
            }
        }
        stage('Installing Dependencies') {
            steps {
                dir('Tetris-V1') {
                    sh 'npm install'
                }
            }
        }
        stage('Trivy File Scan') {
            steps {
                dir('Tetris-V1') {
                    sh 'trivy fs . > trivyfs.txt'
                }
            }
        }
        stage('OWASP Dependency-Check Scan') {
            when {
                anyOf {
                    branch 'main'
                    branch 'dev'
                }
            }
            steps {
                dir('Tetris-V1') {
                    sh 'aws s3 sync s3://cache-bucket-roonyai/nvd-cache /var/lib/jenkins/nvd-cache --quiet || true'
                    withCredentials([string(credentialsId: 'nvd-api-key', variable: 'NVD_API_KEY')]) {
                        sh """
                            /var/lib/jenkins/tools/org.jenkinsci.plugins.DependencyCheck.tools.DependencyCheckInstallation/DP-Check/bin/dependency-check.sh \
                            --scan ./ \
                            --disableYarnAudit \
                            --disableNodeAudit \
                            --nvdApiKey \$NVD_API_KEY \
                            --data /var/lib/jenkins/nvd-cache \
                            --format XML \
                            --out .
                        """
                    }
                    sh 'aws s3 sync /var/lib/jenkins/nvd-cache s3://cache-bucket-roonyai/nvd-cache --quiet'
                    dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                }
            }
        }
        stage("Docker Image Build") {
            when {
                anyOf {
                    branch 'main'
                    branch 'dev'
                }
            }
            steps {
                script {
                    dir('Tetris-V1') {
                        withDockerRegistry(credentialsId: 'docker') {
                            sh 'docker system prune -f'
                            sh 'docker build -t tetrisv1 .'
                        }
                    }
                }
            }
        }
        stage("Docker Image Pushing") {
            when {
                branch 'main'
            }
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker') {
                        sh "docker tag tetrisv1 itoniton/tetrisv1:${BUILD_NUMBER}"
                        sh "docker push itoniton/tetrisv1:${BUILD_NUMBER}"
                    }
                }
            }
        }
        stage("TRIVY Image Scan") {
            when {
                branch 'main'
            }
            steps {
                sh "trivy image itoniton/tetrisv1:${BUILD_NUMBER} > trivyimage.txt"
            }
        }
        stage('Checkout Code') {
            when {
                branch 'main'
            }
            steps {
                git branch: 'main', url: 'https://github.com/kamonphankanthayod/devsecops-game-pipeline.git'
            }
        }
        stage('Update Deployment file') {
            when {
                branch 'main'
            }
            environment {
                GIT_USER_NAME = "kamonphankanthayod"
                GIT_REPO_NAME = "devsecops-game-pipeline"
                MY_GIT_NAME = "Toninwza"
                MY_GIT_EMAIL = "terozeryt@gmail.com"
            }
            steps {
                dir('Manifest-file') {
                    withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                        sh '''
                            git config user.email "${MY_GIT_EMAIL}"
                            git config user.name "${MY_GIT_NAME}"
                            BUILD_NUMBER=${BUILD_NUMBER}
                            echo $BUILD_NUMBER
                            imageTag=$(grep -oP '(?<=tetrisv1:)[^ ]+' deployment-service.yml)
                            echo $imageTag
                            sed -i "s/tetrisv1:${imageTag}/tetrisv1:${BUILD_NUMBER}/" deployment-service.yml
                            git add deployment-service.yml
                            git commit -m "Update deployment Image to version \${BUILD_NUMBER} [skip ci]"
                            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                        '''
                    }
                }
            }
        }
    }
}